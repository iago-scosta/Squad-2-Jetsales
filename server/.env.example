# Copie para .env e ajuste para o seu ambiente.

NODE_ENV=development
PORT=3001

# Database (Postgres) — bate com docker-compose.yaml
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jetsales

# Em produção use DATABASE_URL (Supabase, Neon, RDS...)
# DATABASE_URL=postgres://user:pass@host:5432/db

# JWT — gere com: openssl rand -hex 64
JWT_ACCESS_SECRET=troque-isto-em-producao-access
JWT_REFRESH_SECRET=troque-isto-em-producao-refresh

# CORS — origins do front separados por vírgula
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Domínio dos cookies (produção). Em dev deixe vazio.
# COOKIE_DOMAIN=.jetsales.com.br

# EvolutionAPI (Fase 2)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=

# AI providers (Fase 3)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
