# Template para execução via docker-compose.
# Copie para .env.docker e gere os secrets antes de subir o stack:
#
#   cp server/.env.docker.example server/.env.docker
#   openssl rand -hex 64   # use a saída em JWT_ACCESS_SECRET
#   openssl rand -hex 64   # use a saída em JWT_REFRESH_SECRET
#
# Diferença para .env.example: aqui DB_HOST aponta para o nome do serviço
# postgres dentro da rede do compose (não para localhost).

NODE_ENV=development
PORT=3001

# Database — host é o nome do serviço definido em docker-compose.yaml
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jetsales

# JWT — OBRIGATÓRIO trocar antes de subir. Gere com `openssl rand -hex 64`.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# CORS — origins permitidas, separadas por vírgula
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Domínio dos cookies em produção. Em dev local deixe vazio.
# COOKIE_DOMAIN=.jetsales.com.br

# EvolutionAPI (Fase 2)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=

# AI providers (Fase 3)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
